# DriveLegal.ai Environment Variables
# Copy this file to .env and fill in the values

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=false
PORT=80

# Security (Change this to a long random string in production!)
FLASK_SECRET_KEY=your_super_secret_key_change_me

# SSL / HTTPS
# Set to 1 if you have SSL certificates set up locally (not needed on PythonAnywhere, they handle HTTPS)
USE_SSL=0

# AI Configuration (Gemini)
# Get your API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here
